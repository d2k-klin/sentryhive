# Example environment file for SentryHive (copy to .env, never commit real secrets).
# CLI flags override these. See docs/configuration.md.

# --- AWS (standard SDK variables) ---
# AWS_PROFILE=client-x
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_SESSION_TOKEN=...
AWS_DEFAULT_REGION=eu-central-1

# --- SentryHive ---
# Default EKS cluster for hardeneks (equivalent to --clusters, single value)
# SENTRYHIVE_EKS_CLUSTER=prod-eks
# Default directory ASH scans (equivalent to --source-dir)
# SENTRYHIVE_SOURCE_DIR=./infra
# kubeconfig path for EKS access (equivalent to --kubeconfig)
# KUBECONFIG=~/.kube/client-x

# Used by docker-compose.yml to choose which host dir ASH scans
# SENTRYHIVE_SOURCE=./
