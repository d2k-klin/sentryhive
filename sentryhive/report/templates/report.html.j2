<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>SentryHive Security Report — {{ r.client_name or r.account_id or "scan" }}</title>
<style>
  :root { --bg:#0f172a; --card:#1e293b; --ink:#e2e8f0; --muted:#94a3b8; --line:#334155; }
  * { box-sizing: border-box; }
  body { margin:0; font:14px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
         background:var(--bg); color:var(--ink); }
  header { padding:28px 32px; border-bottom:1px solid var(--line);
           background:linear-gradient(135deg,#1e293b,#0f172a); }
  h1 { margin:0 0 4px; font-size:22px; }
  h1 .hex { color:#fbbf24; }
  .meta { color:var(--muted); font-size:13px; display:flex; flex-wrap:wrap; gap:16px; margin-top:8px; }
  .meta code { color:var(--ink); }
  main { padding:24px 32px; max-width:1200px; margin:0 auto; }
  .cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(120px,1fr)); gap:12px; margin-bottom:24px; }
  .card { background:var(--card); border:1px solid var(--line); border-radius:10px; padding:14px 16px; }
  .card .n { font-size:26px; font-weight:700; }
  .card .l { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
  .sev { display:inline-block; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:700;
         color:#fff; text-transform:uppercase; letter-spacing:.03em; }
  section { background:var(--card); border:1px solid var(--line); border-radius:12px;
            padding:18px 20px; margin-bottom:20px; }
  section h2 { margin:0 0 14px; font-size:16px; }
  table { width:100%; border-collapse:collapse; }
  th,td { text-align:left; padding:9px 10px; border-bottom:1px solid var(--line); vertical-align:top; }
  th { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
  tr:last-child td { border-bottom:none; }
  code { background:#0b1220; padding:1px 6px; border-radius:5px; font-size:12px; word-break:break-all; }
  .controls { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:14px; }
  .controls input, .controls select { background:#0b1220; color:var(--ink); border:1px solid var(--line);
            border-radius:8px; padding:8px 10px; font-size:13px; }
  .controls input { flex:1; min-width:200px; }
  details { margin-top:6px; }
  summary { cursor:pointer; color:var(--muted); }
  .remediation { color:#86efac; }
  .pill { font-size:11px; color:var(--muted); border:1px solid var(--line); border-radius:999px; padding:1px 7px; }
  footer { color:var(--muted); font-size:12px; text-align:center; padding:24px; }
  a { color:#60a5fa; }
  .brand { display:flex; align-items:center; gap:16px; }
  .brand img { max-height:48px; max-width:180px; border-radius:6px; background:#fff; padding:4px; }
  .client { font-size:13px; color:#fbbf24; font-weight:600; text-transform:uppercase; letter-spacing:.05em; }
  .bar { height:10px; border-radius:999px; background:#0b1220; overflow:hidden; min-width:120px; }
  .bar > span { display:block; height:100%; background:#22c55e; }

  /* Cover/scope/TOC are for PDF only; hidden in the browser. */
  @media screen { .print-only { display:none; } }

  /* PDF layout (WeasyPrint / Chromium honor @media print). Paper-friendly: light
     theme, page breaks between sections, repeating footer with page numbers. */
  @media print {
    @page {
      size: A4;
      margin: 18mm 16mm 20mm 16mm;
      @bottom-center {
        content: "SentryHive — Confidential{% if r.client_name %} — {{ r.client_name }}{% endif %} — page " counter(page) " of " counter(pages);
        font-size: 9px; color: #6b7280;
      }
    }
    @page :first { @bottom-center { content: none; } }
    :root { --bg:#fff; --card:#fff; --ink:#111827; --muted:#6b7280; --line:#d1d5db; }
    body { background:#fff; color:#111827; }
    header { background:#fff; border-bottom:2px solid #111827; }
    code { background:#f3f4f6; }
    .controls { display:none !important; }
    header .meta { display:none !important; }
    details { display:none !important; }       /* expand inline instead */
    section { page-break-inside: avoid; }
    h2 { page-break-after: avoid; }
    .cover { page-break-after: always; text-align:center; padding-top:60mm; }
    .cover img { max-height:80px; margin-bottom:24px; }
    .cover .title { font-size:30px; font-weight:700; margin:12px 0; }
    .cover .client { font-size:20px; color:#b45309; margin-bottom:36px; }
    .cover .confidential { display:inline-block; border:2px solid #dc2626; color:#dc2626;
      padding:4px 14px; border-radius:6px; font-weight:700; letter-spacing:.1em; }
    .cover .meta-block { margin-top:40px; font-size:12px; color:#374151; line-height:1.9; }
    .scope, .toc { page-break-after: always; }
    .toc ul { list-style:none; padding:0; }
    .toc a { text-decoration:none; color:#111827; }
    .toc a::after { content: leader('.') target-counter(attr(href), page); }
  }
</style>
</head>
<body>
<!-- ---- PDF-only front matter ---- -->
<div class="print-only cover">
  {% if r.logo_data_uri %}<img src="{{ r.logo_data_uri }}" alt="logo">{% endif %}
  <div class="title">⬡ SentryHive Security Report</div>
  {% if r.client_name %}<div class="client">{{ r.client_name }}</div>{% endif %}
  <div class="confidential">CONFIDENTIAL</div>
  <div class="meta-block">
    {% if r.is_rollup %}Accounts: {{ r.accounts | join(", ") }}<br>
    {% else %}Account: {{ r.account_id or "n/a" }}<br>{% endif %}
    Scan date: {{ r.generated_at }}<br>
    SentryHive v{{ r.tool_version }}
  </div>
</div>

<section class="print-only scope">
  <h2>Scope &amp; methodology</h2>
  <table>
    <tbody>
      {% if r.is_rollup %}
      <tr><th>Accounts scanned</th><td>{{ r.accounts | join(", ") }}</td></tr>
      {% else %}
      <tr><th>Account scanned</th><td>{{ r.account_id or "n/a" }}</td></tr>
      <tr><th>Auth identity</th><td><code>{{ r.identity_arn or "n/a" }}</code></td></tr>
      {% endif %}
      <tr><th>Regions</th><td>{{ r.regions | join(", ") or "n/a" }}</td></tr>
      <tr><th>Scan date</th><td>{{ r.generated_at }}</td></tr>
      <tr><th>SentryHive version</th><td>v{{ r.tool_version }}</td></tr>
      <tr><th>Scanners &amp; versions</th><td>
        {% for s in r.scanners %}{{ s.name }} ({{ s.version or "n/a" }}) — {{ s.status }}{% if not loop.last %}<br>{% endif %}{% endfor %}
      </td></tr>
      <tr><th>Total findings</th><td>{{ r.total }}</td></tr>
    </tbody>
  </table>
  <p style="color:#6b7280;font-size:11px">All scanning and report generation runs locally; no scan data leaves the operator's machine.</p>
</section>

<div class="print-only toc">
  <h2>Contents</h2>
  <ul>
    <li><a href="#sec-summary">Executive summary</a></li>
    {% if r.compliance %}<li><a href="#sec-compliance">Compliance posture</a></li>{% endif %}
    {% if r.iam_highlights %}<li><a href="#sec-iam">IAM privilege-escalation highlights</a></li>{% endif %}
    {% if r.eks_findings %}<li><a href="#sec-eks">EKS Hardening</a></li>{% endif %}
    <li><a href="#sec-findings">All findings</a></li>
  </ul>
</div>

<header>
  <div class="brand">
    {% if r.logo_data_uri %}<img src="{{ r.logo_data_uri }}" alt="client logo">{% endif %}
    <div>
      {% if r.client_name %}<div class="client">{{ r.client_name }}</div>{% endif %}
      <h1><span class="hex">⬡</span> SentryHive Security Report</h1>
    </div>
  </div>
  <div class="meta">
    {% if r.is_rollup %}
    <span>Accounts <code>{{ r.accounts | join(", ") }}</code></span>
    {% else %}
    <span>Account <code>{{ r.account_id or "n/a" }}</code></span>
    <span>Identity <code>{{ r.identity_arn or "n/a" }}</code></span>
    {% endif %}
    <span>Regions <code>{{ r.regions | join(", ") or "n/a" }}</code></span>
    <span>Generated <code>{{ r.generated_at }}</code></span>
    <span>SentryHive <code>v{{ r.tool_version }}</code></span>
  </div>
</header>
<main>
  <div class="cards" id="sec-summary">
    {% for sev in severity_order %}
    <div class="card">
      <div class="n" style="color:{{ severity_colors[sev] }}">{{ r.severity_counts.get(sev, 0) }}</div>
      <div class="l">{{ sev }}</div>
    </div>
    {% endfor %}
    <div class="card"><div class="n">{{ r.total }}</div><div class="l">Total</div></div>
  </div>

  {% if r.compliance %}
  <section id="sec-compliance">
    <h2>Compliance posture</h2>
    <table>
      <thead><tr><th>Framework</th><th>Pass</th><th>Fail</th><th style="width:40%">% pass</th></tr></thead>
      <tbody>
      {% for c in r.compliance %}
        <tr>
          <td><strong>{{ c.framework }}</strong></td>
          <td>{{ c.passed }}</td>
          <td>{{ c.failed }}</td>
          <td>
            <div style="display:flex;align-items:center;gap:8px">
              <div class="bar"><span style="width:{{ c.pass_pct }}%"></span></div>
              <span>{{ c.pass_pct }}%</span>
            </div>
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  {% if r.iam_highlights %}
  <section id="sec-iam">
    <h2>IAM privilege-escalation highlights</h2>
    <p style="color:var(--muted);margin-top:-6px">How an attacker could escalate or take over within this account.</p>
    <table>
      <thead><tr><th>Severity</th><th>Resource</th><th>Finding</th></tr></thead>
      <tbody>
      {% for f in r.iam_highlights %}
        <tr>
          <td><span class="sev" style="background:{{ severity_colors[f.severity.label] }}">{{ f.severity.label }}</span></td>
          <td><code>{{ f.resource }}</code></td>
          <td>{{ f.title or f.check }}{% if f.description %}<br><span style="color:var(--muted)">{{ f.description }}</span>{% endif %}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  {% if r.eks_findings %}
  <section id="sec-eks">
    <h2>EKS Hardening</h2>
    <p style="color:var(--muted);margin-top:-6px">In-cluster best-practice checks (hardeneks). Findings are grouped by cluster.</p>
    <table>
      <thead><tr><th>Severity</th><th>Cluster / resource</th><th>Region</th><th>Finding</th></tr></thead>
      <tbody>
      {% for f in r.eks_findings %}
        <tr>
          <td><span class="sev" style="background:{{ severity_colors[f.severity.label] }}">{{ f.severity.label }}</span></td>
          <td><code>{{ f.resource or "cluster" }}</code></td>
          <td>{{ f.region or "—" }}</td>
          <td><strong>{{ f.title or f.check }}</strong>
            {% if f.remediation %}<br><span class="remediation">→ {{ f.remediation }}</span>{% endif %}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <section>
    <h2>Scanners</h2>
    <table>
      <thead><tr><th>Scanner</th><th>Status</th><th>Findings</th><th>Version</th><th>Notes</th></tr></thead>
      <tbody>
      {% for s in r.scanners %}
        <tr><td>{{ s.name }}</td><td><span class="pill">{{ s.status }}</span></td>
            <td>{{ s.findings }}</td><td><span class="pill">{{ s.version or "—" }}</span></td><td>{{ s.message }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  {% if r.top_risks %}
  <section>
    <h2>Top {{ r.top_risks | length }} risks</h2>
    <table>
      <thead><tr><th>#</th><th>Severity</th><th>Tool</th><th>Resource</th><th>Check</th></tr></thead>
      <tbody>
      {% for f in r.top_risks %}
        <tr>
          <td>{{ loop.index }}</td>
          <td><span class="sev" style="background:{{ severity_colors[f.severity.label] }}">{{ f.severity.label }}</span></td>
          <td>{{ f.tool }}</td>
          <td><code>{{ f.resource or "n/a" }}</code></td>
          <td>{{ f.title or f.check }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <section id="sec-findings">
    <h2>All findings</h2>
    <div class="controls">
      <input id="q" type="search" placeholder="Filter by text (resource, check, description)…">
      <select id="fsev">
        <option value="">All severities</option>
        {% for sev in severity_order %}<option value="{{ sev }}">{{ sev }}</option>{% endfor %}
      </select>
      <select id="ftool">
        <option value="">All tools</option>
        {% for s in r.scanners %}<option value="{{ s.name }}">{{ s.name }}</option>{% endfor %}
      </select>
      <select id="fstatus">
        <option value="">All statuses</option>
        <option value="fail">fail</option>
        <option value="pass">pass</option>
        <option value="info">info</option>
      </select>
    </div>
    <table id="findings">
      <thead><tr><th>Severity</th><th>Tool</th><th>Service</th><th>Resource</th><th>Finding</th></tr></thead>
      <tbody>
      {% for f in r.findings %}
        <tr class="frow" data-sev="{{ f.severity.label }}" data-tool="{{ f.tool }}" data-status="{{ f.status }}"
            data-text="{{ (f.title ~ ' ' ~ f.check ~ ' ' ~ f.resource ~ ' ' ~ f.description ~ ' ' ~ f.service) | lower }}">
          <td><span class="sev" style="background:{{ severity_colors[f.severity.label] }}">{{ f.severity.label }}</span></td>
          <td>{{ f.tool }}</td>
          <td>{{ f.service or "—" }}{% if f.region %}<br><span class="pill">{{ f.region }}</span>{% endif %}</td>
          <td><code>{{ f.resource or "n/a" }}</code></td>
          <td>
            <strong>{{ f.title or f.check }}</strong>
            <span class="pill">{{ f.status }}</span>
            {% if r.is_rollup and f.account_id %}<span class="pill">acct {{ f.account_id }}</span>{% endif %}
            {% for c in f.compliance_refs %}{% if not c.startswith("flagged-by") %}<span class="pill">{{ c }}</span>{% endif %}{% endfor %}
            <details>
              <summary>details</summary>
              {% if f.description %}<p>{{ f.description }}</p>{% endif %}
              {% if f.remediation %}<p class="remediation">→ {{ f.remediation }}</p>{% endif %}
              <p><span class="pill">id: {{ f.id }}</span> <span class="pill">check: {{ f.check }}</span> <span class="pill">source: {{ f.tool }}</span></p>
            </details>
            <div class="print-only">
              {% if f.description %}<p style="margin:4px 0">{{ f.description }}</p>{% endif %}
              {% if f.remediation %}<p class="remediation" style="margin:4px 0">→ {{ f.remediation }}</p>{% endif %}
              <p style="font-size:11px;color:#6b7280">check: {{ f.check }} · source: {{ f.tool }}</p>
            </div>
          </td>
        </tr>
      {% else %}
        <tr><td colspan="5">No findings.</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
</main>
<footer>
  Generated by <a href="https://github.com/d2k-klin/sentryhive">SentryHive</a> ·
  no data leaves your machine
</footer>
<script>
  const q = document.getElementById('q');
  const fsev = document.getElementById('fsev');
  const ftool = document.getElementById('ftool');
  const fstatus = document.getElementById('fstatus');
  const rows = Array.from(document.querySelectorAll('.frow'));
  function apply() {
    const text = q.value.trim().toLowerCase();
    const sev = fsev.value, tool = ftool.value, status = fstatus.value;
    rows.forEach(r => {
      const ok = (!text || r.dataset.text.includes(text))
        && (!sev || r.dataset.sev === sev)
        && (!tool || r.dataset.tool === tool)
        && (!status || r.dataset.status === status);
      r.style.display = ok ? '' : 'none';
    });
  }
  [q, fsev, ftool, fstatus].forEach(el => el.addEventListener('input', apply));
</script>
</body>
</html>
