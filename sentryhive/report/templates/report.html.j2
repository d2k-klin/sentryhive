<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>SentryHive Security Report — {{ r.account_id or "scan" }}</title>
<style>
  :root { --bg:#0f172a; --card:#1e293b; --ink:#e2e8f0; --muted:#94a3b8; --line:#334155; }
  * { box-sizing: border-box; }
  body { margin:0; font:14px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
         background:var(--bg); color:var(--ink); }
  header { padding:28px 32px; border-bottom:1px solid var(--line);
           background:linear-gradient(135deg,#1e293b,#0f172a); }
  h1 { margin:0 0 4px; font-size:22px; }
  h1 .hex { color:#fbbf24; }
  .meta { color:var(--muted); font-size:13px; display:flex; flex-wrap:wrap; gap:16px; margin-top:8px; }
  .meta code { color:var(--ink); }
  main { padding:24px 32px; max-width:1200px; margin:0 auto; }
  .cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(120px,1fr)); gap:12px; margin-bottom:24px; }
  .card { background:var(--card); border:1px solid var(--line); border-radius:10px; padding:14px 16px; }
  .card .n { font-size:26px; font-weight:700; }
  .card .l { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
  .sev { display:inline-block; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:700;
         color:#fff; text-transform:uppercase; letter-spacing:.03em; }
  section { background:var(--card); border:1px solid var(--line); border-radius:12px;
            padding:18px 20px; margin-bottom:20px; }
  section h2 { margin:0 0 14px; font-size:16px; }
  table { width:100%; border-collapse:collapse; }
  th,td { text-align:left; padding:9px 10px; border-bottom:1px solid var(--line); vertical-align:top; }
  th { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
  tr:last-child td { border-bottom:none; }
  code { background:#0b1220; padding:1px 6px; border-radius:5px; font-size:12px; word-break:break-all; }
  .controls { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:14px; }
  .controls input, .controls select { background:#0b1220; color:var(--ink); border:1px solid var(--line);
            border-radius:8px; padding:8px 10px; font-size:13px; }
  .controls input { flex:1; min-width:200px; }
  details { margin-top:6px; }
  summary { cursor:pointer; color:var(--muted); }
  .remediation { color:#86efac; }
  .pill { font-size:11px; color:var(--muted); border:1px solid var(--line); border-radius:999px; padding:1px 7px; }
  footer { color:var(--muted); font-size:12px; text-align:center; padding:24px; }
  a { color:#60a5fa; }
</style>
</head>
<body>
<header>
  <h1><span class="hex">⬡</span> SentryHive Security Report</h1>
  <div class="meta">
    <span>Account <code>{{ r.account_id or "n/a" }}</code></span>
    <span>Identity <code>{{ r.identity_arn or "n/a" }}</code></span>
    <span>Regions <code>{{ r.regions | join(", ") or "n/a" }}</code></span>
    <span>Generated <code>{{ r.generated_at }}</code></span>
  </div>
</header>
<main>
  <div class="cards">
    {% for sev in severity_order %}
    <div class="card">
      <div class="n" style="color:{{ severity_colors[sev] }}">{{ r.severity_counts.get(sev, 0) }}</div>
      <div class="l">{{ sev }}</div>
    </div>
    {% endfor %}
    <div class="card"><div class="n">{{ r.total }}</div><div class="l">Total</div></div>
  </div>

  <section>
    <h2>Scanners</h2>
    <table>
      <thead><tr><th>Scanner</th><th>Status</th><th>Findings</th><th>Notes</th></tr></thead>
      <tbody>
      {% for s in r.scanners %}
        <tr><td>{{ s.name }}</td><td><span class="pill">{{ s.status }}</span></td>
            <td>{{ s.findings }}</td><td>{{ s.message }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>

  {% if r.top_risks %}
  <section>
    <h2>Top {{ r.top_risks | length }} risks</h2>
    <table>
      <thead><tr><th>#</th><th>Severity</th><th>Tool</th><th>Resource</th><th>Check</th></tr></thead>
      <tbody>
      {% for f in r.top_risks %}
        <tr>
          <td>{{ loop.index }}</td>
          <td><span class="sev" style="background:{{ severity_colors[f.severity.label] }}">{{ f.severity.label }}</span></td>
          <td>{{ f.tool }}</td>
          <td><code>{{ f.resource or "n/a" }}</code></td>
          <td>{{ f.title or f.check }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  <section>
    <h2>All findings</h2>
    <div class="controls">
      <input id="q" type="search" placeholder="Filter by text (resource, check, description)…">
      <select id="fsev">
        <option value="">All severities</option>
        {% for sev in severity_order %}<option value="{{ sev }}">{{ sev }}</option>{% endfor %}
      </select>
      <select id="ftool">
        <option value="">All tools</option>
        {% for s in r.scanners %}<option value="{{ s.name }}">{{ s.name }}</option>{% endfor %}
      </select>
      <select id="fstatus">
        <option value="">All statuses</option>
        <option value="fail">fail</option>
        <option value="pass">pass</option>
        <option value="info">info</option>
      </select>
    </div>
    <table id="findings">
      <thead><tr><th>Severity</th><th>Tool</th><th>Service</th><th>Resource</th><th>Finding</th></tr></thead>
      <tbody>
      {% for f in r.findings %}
        <tr class="frow" data-sev="{{ f.severity.label }}" data-tool="{{ f.tool }}" data-status="{{ f.status }}"
            data-text="{{ (f.title ~ ' ' ~ f.check ~ ' ' ~ f.resource ~ ' ' ~ f.description ~ ' ' ~ f.service) | lower }}">
          <td><span class="sev" style="background:{{ severity_colors[f.severity.label] }}">{{ f.severity.label }}</span></td>
          <td>{{ f.tool }}</td>
          <td>{{ f.service or "—" }}{% if f.region %}<br><span class="pill">{{ f.region }}</span>{% endif %}</td>
          <td><code>{{ f.resource or "n/a" }}</code></td>
          <td>
            <strong>{{ f.title or f.check }}</strong>
            <span class="pill">{{ f.status }}</span>
            <details>
              <summary>details</summary>
              {% if f.description %}<p>{{ f.description }}</p>{% endif %}
              {% if f.remediation %}<p class="remediation">→ {{ f.remediation }}</p>{% endif %}
              {% if f.compliance_refs %}<p>{% for c in f.compliance_refs %}<span class="pill">{{ c }}</span> {% endfor %}</p>{% endif %}
              <p><span class="pill">id: {{ f.id }}</span> <span class="pill">check: {{ f.check }}</span></p>
            </details>
          </td>
        </tr>
      {% else %}
        <tr><td colspan="5">No findings.</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
</main>
<footer>
  Generated by <a href="https://github.com/d2k-klin/sentryhive">SentryHive</a> ·
  no data leaves your machine
</footer>
<script>
  const q = document.getElementById('q');
  const fsev = document.getElementById('fsev');
  const ftool = document.getElementById('ftool');
  const fstatus = document.getElementById('fstatus');
  const rows = Array.from(document.querySelectorAll('.frow'));
  function apply() {
    const text = q.value.trim().toLowerCase();
    const sev = fsev.value, tool = ftool.value, status = fstatus.value;
    rows.forEach(r => {
      const ok = (!text || r.dataset.text.includes(text))
        && (!sev || r.dataset.sev === sev)
        && (!tool || r.dataset.tool === tool)
        && (!status || r.dataset.status === status);
      r.style.display = ok ? '' : 'none';
    });
  }
  [q, fsev, ftool, fstatus].forEach(el => el.addEventListener('input', apply));
</script>
</body>
</html>
